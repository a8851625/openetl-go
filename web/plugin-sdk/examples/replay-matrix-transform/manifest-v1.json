{
  "name": "replay-matrix-transform",
  "kind": "transform",
  "version": "1.0.0",
  "abi": "openetl.plugin.abi/v1",
  "min_runtime_version": "openetl-runtime/v1",
  "entrypoints": ["transform"],
  "capabilities": ["one_to_many", "drop", "failure_injection", "dlq_replay"],
  "config": [
    {
      "name": "label",
      "type": "string",
      "required": true,
      "description": "Marker copied to successful output records"
    },
    {
      "name": "api_token",
      "type": "string",
      "required": true,
      "secret": true,
      "description": "Secret used to verify manifest/config handling; never emitted"
    }
  ]
}
